# Copy to .env and fill in real values. .env is gitignored and never pushed.
# GitHub Actions cannot read this file — duplicate each value as a repo secret:
#   https://github.com/agenticstandardcontact-byte/agentic-architect/settings/secrets/actions
#
#   DEVTO_API_KEY
#   BLUESKY_HANDLE
#   (Hashnode API skipped — manual cross-post only)
#   BLUESKY_APP_PASSWORD
#   MASTODON_TOKEN          (optional)
#   MASTODON_INSTANCE       (optional, e.g. https://hachyderm.io)

# dev.to → Settings → Extensions → DEV Community API Keys
DEVTO_API_KEY=

# Hashnode — skipped (API needs Pro). Leave empty; cross-post in the editor instead.
# HASHNODE_API_KEY=
# HASHNODE_PUBLICATION_ID=

# Bluesky uses an "app password", not a developer API key (see comments below)
BLUESKY_HANDLE=yourname.bsky.social
BLUESKY_APP_PASSWORD=

# Mastodon (optional until instance approves your account)
MASTODON_TOKEN=
MASTODON_INSTANCE=
