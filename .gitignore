# --------------------------------------------------------------------
# LOCAL-ONLY DEV NOTES, DRAFTS, AND MARKETING WORKING FILES
# Anything matching these patterns stays on disk and never gets pushed.
# README.md, LICENSE, and rules/persistence-kit.md are the only .md files
# that should ever be tracked in this repo — everything else is internal.
# --------------------------------------------------------------------

# Named working files (session continuity: use .local/SESSION-LOG.md only)
HANDOFF.md
HANDOFF*.md
LAUNCH.md
LAUNCH*.md
SITE_NOTES.md

# Pattern-based protection (default-private for future .md files)
*.handoff.md
*.draft.md
*.local.md
*.private.md
*.notes.md
*.scratch.md

# Folders sometimes used for working notes
handoff/
notes/
drafts/
scratch/

# Marketing PR helpers (local only)
scripts/awesome-dotnet-prs.py
scripts/pr-body-*.md

# Working submission / cross-post files
cursor-directory-submission.mdc
devto-*.md
medium-*.md
hashnode-*.md
linkedin-*.md
hn-*.md
reddit-*.md
twitter-*.md
x-thread-*.md

# Local API keys (never commit — .env.example is the template)
.env
.env.local
.env.*.local

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Node (Playwright local runs)
node_modules/

# Editor scratch
*.swp
*.swo
*~
.vscode/
.idea/

# Local backups
*.bak

# History rewrite tool (local only, never pushed)
.mailmap

# Marketing ops: skills, agents, strategy, command cheatsheets (never public)
.local/
.cursor/skills/
commands.txt
COMMANDS.txt
**/agentic-marketing/
